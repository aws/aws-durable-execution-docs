<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Template used by verify.sh to compile a TEST example together with its companion
    workflow file (both copied into a temp dir). __TB__ is replaced with the absolute
    path to the prebuilt Testing SDK output. Compiles every .cs in the temp dir.
  -->

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <OutputType>Library</OutputType>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="Amazon.Lambda.Core">
      <HintPath>__TB__/Amazon.Lambda.Core.dll</HintPath>
    </Reference>
    <Reference Include="Amazon.Lambda.DurableExecution">
      <HintPath>__TB__/Amazon.Lambda.DurableExecution.dll</HintPath>
    </Reference>
    <Reference Include="Amazon.Lambda.DurableExecution.Testing">
      <HintPath>__TB__/Amazon.Lambda.DurableExecution.Testing.dll</HintPath>
    </Reference>
    <PackageReference Include="xunit" Version="2.9.2" />
  </ItemGroup>

</Project>
